# Russian Book to Audio — Конфигурация
# Скопируйте в .env и измените при необходимости

# Директория для выходных аудиофайлов (по умолчанию: output/)
# OUTPUT_DIR=output

# Путь к SQLite базе данных (по умолчанию: jobs.db)
# DB_PATH=jobs.db

# Параметры TTS
# MAX_CHARS_PER_CHUNK=600
# MIN_CHARS_PER_CHUNK=400
# MEMORY_REDUCTION_FACTOR=0.7

# Параметры MP3
# MP3_BITRATE_KBPS=128
# MP3_QUALITY_NORMAL=2
